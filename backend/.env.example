cd # MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=easymarket_db

# Server
PORT=3001
NODE_ENV=production

# Auth
JWT_SECRET=replace_with_a_long_random_string
ADMIN_SECRET=replace_with_a_long_random_string

# Admin
ADMIN_EMAIL=admin@easymarket.pe
ADMIN_PASSWORD=change_me
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# Shipping
DELIVERY_COST=10
FREE_SHIPPING_THRESHOLD=150

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=EasyMarket <no-reply@easymarket.pe>
OFFER_ALERT_THRESHOLD=50