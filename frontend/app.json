{
  "expo": {
    "name": "EasyMarket",
    "slug": "easymarket",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "easymarket",
    "userInterfaceStyle": "automatic",
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.easymarket.app" },
    "android": { "package": "com.easymarket.app" },
    "web": { "bundler": "metro", "output": "static" },
    "plugins": ["expo-router"],
    "experiments": { "typedRoutes": true }
  }
}